setupcygwin() {(
  set -e
  EXE=setup-x86_64.exe
  TMPFILE=$(mktemp -d)/${EXE}
  wget https://www.cygwin.com/${EXE} -O "$TMPFILE"
  chmod +x "$TMPFILE"
  start "$(cygpath -w "$TMPFILE")"
